generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  businessId    String?
  phoneNumber   String
  walletBalance Float     @default(0.0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  business      Business? @relation(fields: [businessId], references: [id], onDelete: SetNull)

  @@unique([businessId, phoneNumber])
  @@index([businessId])
}

model UssdSession {
  id          String    @id @default(uuid())
  businessId  String?
  sessionId   String    @unique
  phoneNumber String
  state       String    // e.g. MAIN_MENU, ENTER_AMOUNT, ENTER_TARGET, CONFIRM
  targetPhone String?
  amount      Float?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  business    Business? @relation(fields: [businessId], references: [id], onDelete: SetNull)

  @@index([businessId])
}

model SavedPhone {
  id          String    @id @default(uuid())
  businessId  String?
  phoneNumber String    // Owner
  savedNumber String    // Target
  createdAt   DateTime  @default(now())

  business    Business? @relation(fields: [businessId], references: [id], onDelete: SetNull)

  @@unique([businessId, phoneNumber, savedNumber])
  @@index([businessId])
}

model Transaction {
  id                String    @id @default(uuid())
  businessId        String?
  transactionId     String    @unique
  phoneNumber       String
  targetPhone       String
  amount            Float
  status            String    // PENDING_STK, STK_SUCCESS, AIRTIME_DELIVERED, FAILED
  providerReference String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  business          Business? @relation(fields: [businessId], references: [id], onDelete: SetNull)

  @@index([businessId])
}

enum AdminRole {
  SUPERADMIN
  BUSINESS_OWNER
  BUSINESS_STAFF
  MODERATOR
}

enum BusinessStatus {
  ACTIVE
  SUSPENDED
}

model Business {
  id                     String         @id @default(uuid())
  name                   String
  slug                   String         @unique
  serviceCode            String?        @unique
  status                 BusinessStatus @default(ACTIVE)
  subscriptionEndsAt     DateTime?
  ownerName              String?
  ownerEmail             String?
  ownerPhone             String?
  description            String?
  mpesaConsumerKey       String?
  mpesaConsumerSecret    String?
  mpesaPasskey           String?
  mpesaShortcode         String?
  mpesaBusinessShortcode String?
  mpesaPartyB            String?
  mpesaEnvironment       String         @default("production")
  mpesaTransactionType   String         @default("CustomerBuyGoodsOnline")
  mpesaCallbackUrl       String?
  tupayUuid              String?
  tupayApiKey            String?
  tupaySecret            String?
  smsProvider            String?
  smsPartnerId           String?
  smsApiKey              String?
  smsSenderId            String?
  smsAccessKey           String?
  smsClientId            String?
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  admins                 Admin[]
  users                  User[]
  ussdSessions           UssdSession[]
  savedPhones            SavedPhone[]
  transactions           Transaction[]
  notificationLogs       NotificationLog[]
}

model Admin {
  id         String    @id @default(uuid())
  email      String    @unique
  password   String    // Hashed
  name       String?
  phoneNumber String?
  role       AdminRole @default(MODERATOR)
  businessId String?
  business   Business? @relation(fields: [businessId], references: [id], onDelete: SetNull)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  loginOtps  LoginOtp[]
}

model LoginOtp {
  id          String   @id @default(uuid())
  adminId     String
  codeHash    String
  expiresAt   DateTime
  attempts    Int      @default(0)
  consumedAt  DateTime?
  sentToEmail String?
  sentToPhone String?
  createdAt   DateTime @default(now())
  admin       Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId, expiresAt])
}

model NotificationLog {
  id         String   @id @default(uuid())
  businessId String?
  kind       String
  channel    String
  recipient  String
  dedupeKey  String   @unique
  subject    String?
  message    String   @db.Text
  status     String
  metadata   String?  @db.Text
  createdAt  DateTime @default(now())
  business   Business? @relation(fields: [businessId], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([kind])
}

model SystemSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
